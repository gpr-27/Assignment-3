apiVersion: v1
kind: Secret
metadata:
  name: notewise-secrets
  namespace: notewise
type: Opaque
stringData:
  # Replace with your values; do not commit real secrets. Copy to secret.yaml locally.
  MONGO_URI: "mongodb://USER:PASSWORD@mongo-service:27017/notewise?authSource=admin"
  GROQ_API_KEY: "your-groq-api-key"
  JWT_SECRET: "your-long-random-jwt-secret"
  MONGO_INITDB_ROOT_USERNAME: "notewise"
  MONGO_INITDB_ROOT_PASSWORD: "your-mongo-password"
